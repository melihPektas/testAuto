{
  "name": "@test-orchestrator/agent",
  "version": "0.0.1",
  "description": "LLM-backed intelligence for test-orchestrator: authors meaningful test cases from an exploration",
  "type": "module",
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js"
    },
    "./package.json": "./package.json"
  },
  "files": [
    "dist"
  ],
  "scripts": {
    "build": "tsc -b",
    "dev": "tsc -b --watch",
    "lint": "eslint . --max-warnings 0",
    "lint:fix": "eslint . --fix",
    "test": "vitest run",
    "test:ci": "vitest run --reporter=dot --coverage",
    "check-types": "tsc --noEmit",
    "clean": "rm -rf dist .turbo coverage *.tsbuildinfo"
  },
  "dependencies": {
    "@test-orchestrator/browser": "workspace:*",
    "@test-orchestrator/schema": "workspace:*"
  },
  "devDependencies": {
    "@types/node": "^20.12.0",
    "vitest": "^1.6.0",
    "@vitest/coverage-v8": "^1.6.0"
  }
}
