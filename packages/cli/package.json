{
  "name": "@test-orchestrator/cli",
  "version": "0.0.1",
  "description": "CLI entrypoint for test-orchestrator - exposes init, run, generate, report, plugin",
  "type": "module",
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "bin": {
    "test-orchestrator": "./bin/test-orchestrator.js",
    "to": "./bin/test-orchestrator.js"
  },
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js"
    },
    "./commands": {
      "types": "./dist/commands/index.d.ts",
      "import": "./dist/commands/index.js"
    },
    "./package.json": "./package.json"
  },
  "files": ["dist", "bin", "templates"],
  "scripts": {
    "build": "tsc -b",
    "dev": "tsc -b --watch",
    "lint": "eslint . --max-warnings 0",
    "lint:fix": "eslint . --fix",
    "test": "vitest run",
    "test:ci": "vitest run --reporter=dot --coverage",
    "check-types": "tsc --noEmit",
    "start": "node bin/test-orchestrator.js",
    "clean": "rm -rf dist .turbo coverage *.tsbuildinfo"
  },
  "dependencies": {
    "@test-orchestrator/core": "workspace:*",
    "@test-orchestrator/schema": "workspace:*",
    "chalk": "^5.3.0",
    "commander": "^12.1.0"
  },
  "devDependencies": {
    "@types/node": "^20.12.0",
    "execa": "^9.1.0",
    "vitest": "^1.6.0",
    "@vitest/coverage-v8": "^1.6.0"
  }
}
