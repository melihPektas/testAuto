{
  "name": "@test-orchestrator/browser",
  "version": "0.0.1",
  "description": "Playwright browser runner + URL UI-test generator for test-orchestrator",
  "type": "module",
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js"
    },
    "./package.json": "./package.json"
  },
  "files": [
    "dist"
  ],
  "scripts": {
    "build": "tsc -b",
    "dev": "tsc -b --watch",
    "lint": "eslint . --max-warnings 0",
    "lint:fix": "eslint . --fix",
    "test": "vitest run",
    "test:ci": "vitest run --reporter=dot --coverage",
    "check-types": "tsc --noEmit",
    "clean": "rm -rf dist .turbo coverage *.tsbuildinfo"
  },
  "dependencies": {
    "@test-orchestrator/core": "workspace:*",
    "axe-core": "^4.12.1",
    "pixelmatch": "^7.2.0",
    "playwright": "^1.45.0",
    "pngjs": "^7.0.0"
  },
  "devDependencies": {
    "@types/node": "^20.12.0",
    "@types/pngjs": "^6.0.5",
    "@vitest/coverage-v8": "^1.6.0",
    "vitest": "^1.6.0"
  }
}
