{
  "id": "matrix-women-h-m",
  "version": "1.0",
  "name": "Results for Women + H&M",
  "runner": "ui",
  "steps": [
    {
      "id": "goto",
      "action": "goto",
      "value": "https://automationexercise.com/brand_products/H&M"
    },
    {
      "id": "status",
      "action": "expectStatus",
      "value": 200
    },
    {
      "id": "results",
      "action": "expectMinCount",
      "target": ".productinfo",
      "value": 1
    },
    {
      "id": "no-errors",
      "action": "expectNoConsoleErrors"
    }
  ]
}
