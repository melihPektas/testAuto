{
  "id": "matrix-tshirts-polo-pants",
  "version": "1.0",
  "name": "Results for Tshirts + Polo + search \"pants\"",
  "runner": "ui",
  "steps": [
    {
      "id": "goto",
      "action": "goto",
      "value": "https://automationexercise.com/brand_products/Polo"
    },
    {
      "id": "status",
      "action": "expectStatus",
      "value": 200
    },
    {
      "id": "search",
      "action": "fill",
      "target": "#search_product",
      "value": "pants"
    },
    {
      "id": "submit",
      "action": "press",
      "target": "#search_product",
      "value": "Enter"
    },
    {
      "id": "results",
      "action": "expectMinCount",
      "target": ".productinfo",
      "value": 1
    },
    {
      "id": "no-errors",
      "action": "expectNoConsoleErrors"
    }
  ]
}
