{
  "id": "login-with-invalid-credentials",
  "version": "1.0",
  "name": "User fails to log in with invalid email and password",
  "steps": [
    {
      "action": "goto",
      "value": "http://localhost:4700/login"
    },
    {
      "action": "expectStatus",
      "value": 200
    },
    {
      "action": "fill",
      "target": "input[name='email']",
      "value": "invalid@example.com"
    },
    {
      "action": "fill",
      "target": "input[name='password']",
      "value": "wrongPassword"
    },
    {
      "action": "click",
      "target": "button[type='submit']"
    },
    {
      "action": "waitFor",
      "target": ".error-message"
    },
    {
      "action": "expectText",
      "value": "Invalid email or password."
    }
  ],
  "runner": "ui",
  "timeout": 30000,
  "retry": 0
}
